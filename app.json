{
  "expo": {
    "name": "Carbon",
    "slug": "carbon-fitness",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "carbon",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080A0E",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080A0E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.carbon.fitness",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080A0E"
      },
      "package": "com.carbon.fitness"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
